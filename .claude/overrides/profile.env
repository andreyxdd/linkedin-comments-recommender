# Default profile for GitHub + Ralph workflow

# Branch and labels
RALPH_BASE_BRANCH=main
RALPH_PRD_LABEL_PREFIX=prd
RALPH_AFK_LABEL=afk
RALPH_HITL_LABEL=hitl
RALPH_NEEDS_REVIEW_LABEL=needs-review

# Claude invocation command templates
# Available placeholders:
# - {{repo}}
# - {{issue}}
# - {{pr}}
# - {{base_branch}}
RALPH_IMPLEMENT_CMD='docker sandbox run claude -- -p "Implement GitHub issue #{{issue}} in this repository ({{repo}}). Stay on branch {{base_branch}}, implement acceptance criteria, commit with conventional commits, and reference Closes #{{issue}}." --allowedTools "Bash,Read,Edit,Write,Glob,Grep,Agent"'
RALPH_IMPLEMENT_PR_CMD='docker sandbox run claude -- -p "Implement GitHub issue #{{issue}} in this repository ({{repo}}). Create branch issue-{{issue}}, commit changes, push branch, and open a PR targeting {{base_branch}} with Closes #{{issue}}." --allowedTools "Bash,Read,Edit,Write,Glob,Grep,Agent"'
RALPH_REVIEW_CMD='docker sandbox run claude -- -p "Review PR #{{pr}} in repository {{repo}} against issue #{{issue}}." --agent code-reviewer --allowedTools "Bash,Read,Glob,Grep"'
RALPH_FIX_PR_CMD='docker sandbox run claude -- -p "PR #{{pr}} in repository {{repo}} received review feedback for issue #{{issue}}. Read comments, apply requested changes, commit, and push." --allowedTools "Bash,Read,Edit,Write,Glob,Grep,Agent"'
