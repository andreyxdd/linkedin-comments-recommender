# LLM Provider: "anthropic" or "openai"
LLM_PROVIDER=anthropic

# Anthropic (default)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI (if LLM_PROVIDER=openai)
# OPENAI_API_KEY=your-openai-api-key-here

# Apify configuration for live LinkedIn discovery
APIFY_API_TOKEN=your-apify-token-here
# APIFY_POSTS_ACTOR_ID=apimaestro/linkedin-posts-search-scraper-no-cookies
# APIFY_REACTIONS_ACTOR_ID=harvestapi/linkedin-post-reactions
# REACTION_ENRICHMENT_COUNT=8
# MAX_REACTIONS_PER_POST=20

# Model overrides (optional)
# GENERATION_MODEL=claude-sonnet-4-20250514
# EVALUATION_MODEL=claude-haiku-4-5-20251001

# Graph settings (optional)
# MAX_ITERATIONS=3
# MIN_QUALITY_SCORE=0.7

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000
